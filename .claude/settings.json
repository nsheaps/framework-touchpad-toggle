{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mise run:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(bash test/smoke.sh)",
      "Bash(brew audit:*)",
      "Bash(brew style:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Read(./**)",
      "Edit(./**)"
    ],
    "deny": [
      "Read(./**/*.local.*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/lint-shell.sh"
          }
        ]
      }
    ]
  }
}
